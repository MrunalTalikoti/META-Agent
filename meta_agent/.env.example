# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metaagent

# Cache
REDIS_URL=redis://localhost:6379/0

# LLM APIs (fill these in Day 2)
OPENAI_API_KEY=your_openai_key_here
